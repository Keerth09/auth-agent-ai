# ============================================================
# Agent Control Center — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_RANDOM_SECRET_AT_LEAST_32_CHARS

# ── Auth0 Regular Web Application ────────────────────────────
# Dashboard → Applications → Create Application → Regular Web App
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_CALLBACK_URL=http://localhost:3000/auth/callback
AUTH0_BASE_URL=http://localhost:3000

# Required scopes for the Auth0 session (space-separated)
# 'openid profile email' are standard OIDC scopes
# 'offline_access' enables refresh token issuance for token vault
AUTH0_SCOPE=openid profile email offline_access

# ── Auth0 Management API (Machine-to-Machine) ────────────────
# Dashboard → Applications → Create Application → Machine to Machine
# Authorize it for: Auth0 Management API
# Required Management API Scopes: read:grants delete:grants read:users
AUTH0_M2M_CLIENT_ID=your-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=your-m2m-client-secret
AUTH0_M2M_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# ── Token Vault / Social Connection Names ────────────────────
# This must match the connection name in your Auth0 dashboard
# Dashboard → Authentication → Social → Google → "Name" field
AUTH0_CONNECTION_GOOGLE=google-oauth2

# ── Database ─────────────────────────────────────────────────
# Path to SQLite database file. Leave empty for in-memory (:memory:)
DB_PATH=./data/acc.db

# ── Agent Settings ───────────────────────────────────────────
AGENT_DEFAULT_TIMEOUT_MS=30000
AGENT_MAX_PENDING_APPROVALS=50
