# ============================================================
# VaultProxy — Environment Variables
# ============================================================
# Copy this file: cp .env.local.example .env.local
# Then fill in your values from:
#   Auth0 Dashboard → https://manage.auth0.com/
# ============================================================

# ── Auth0 Core (Required) ────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH0_SECRET=replace_with_output_of_openssl_rand_hex_32

# Your app's base URL (no trailing slash)
AUTH0_BASE_URL=http://localhost:3000

# Your Auth0 tenant domain
AUTH0_ISSUER_BASE_URL=https://YOUR-TENANT.us.auth0.com

# From Auth0 Dashboard → Applications → Your App → Settings
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here

# ── Auth0 Management API (for Token Vault & Revocation) ──────
# Create a Machine-to-Machine app in Auth0 Dashboard
# Grant it: read:grants, delete:grants
AUTH0_MGMT_CLIENT_ID=your_mgmt_app_client_id
AUTH0_MGMT_CLIENT_SECRET=your_mgmt_app_client_secret

# ── Google OAuth Connection ───────────────────────────────────
# Auth0 handles Google OAuth — set this to match your
# Auth0 Social Connection name (usually "google-oauth2")
AUTH0_CONNECTION_GOOGLE=google-oauth2

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (optional override) ─────────────────────────────
# Defaults to ./main.db in project root
# DB_PATH=./main.db

# ============================================================
# SETUP CHECKLIST:
# ============================================================
# 1. Generate AUTH0_SECRET:
#    Mac/Linux: openssl rand -hex 32
#    Windows:   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. Auth0 Dashboard → Applications → Create App:
#    Type: Regular Web Application
#    Allowed Callback URLs: http://localhost:3000/api/auth/callback
#    Allowed Logout URLs:   http://localhost:3000
#    Allowed Web Origins:   http://localhost:3000
#
# 3. Auth0 Dashboard → Authentication → Social:
#    Enable Google OAuth2 (use your Google Cloud credentials)
#    ✅ Enable "Token Vault" on the Google connection
#    ✅ Enable "offline_access" scope for refresh tokens
#
# 4. Auth0 Dashboard → Applications → APIs:
#    Create Machine-to-Machine app targeting Auth0 Management API
#    Grant scopes: read:grants, delete:grants
#
# 5. Run: npm run dev → http://localhost:3000
# ============================================================
